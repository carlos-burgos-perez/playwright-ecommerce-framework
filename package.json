{
  "name": "playwright-ecommerce-framework",
  "version": "1.0.0",
  "description": "��#\u0000 \u0000p\u0000l\u0000a\u0000y\u0000w\u0000r\u0000i\u0000g\u0000h\u0000t\u0000-\u0000e\u0000c\u0000o\u0000m\u0000m\u0000e\u0000r\u0000c\u0000e\u0000-\u0000f\u0000r\u0000a\u0000m\u0000e\u0000w\u0000o\u0000r\u0000k\u0000\r\u0000 \u0000",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright show-report",
    "test:ci": "npx playwright test --reporter=dot",
    "test:ci:headed": "npx playwright test --headed --reporter=dot",
    "test:ci:debug": "npx playwright test --debug --reporter=dot",
    "test:ci:report": "npx playwright show-report --reporter=dot",
    "test:allure": "npx playwright test --reporter=list,allure-playwright",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "node -e \"const fs=require('fs'); ['allure-results','allure-report'].forEach((dir)=>fs.rmSync(dir,{recursive:true,force:true}));\" && npm run test:allure && allure serve allure-results",
    "allure:server": "npm run allure:serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlos-burgos-perez/playwright-ecommerce-framework.git"
  },
