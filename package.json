  "homepage": "https://github.com/carlos-burgos-perez/playwright-ecommerce-framework#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "allure-js-commons": "^3.10.2",
    "dotenv": "^17.4.2"
  }
